{
  "name": "obsidian-format-with-prettier-el",
  "version": "0.18.1",
  "description": "Format vault files using Prettier.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,js,css}\" --config .prettierrc",
    "check-format": "prettier --check \"src/**/*.{ts,js,css}\" --config .prettierrc",
    "test": "vitest run"
  },
  "keywords": [
    "Obsidian plugin",
    "Obsidian",
    "regex"
  ],
  "license": "MIT",
  "dependencies": {
    "builtin-modules": "^5.3.0",
    "common-tags": "^1.8.2",
    "obsidian": "1.13.0",
    "prettier": "3.8.3",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/common-tags": "^1.8.4",
    "@types/node": "^20.19.43",
    "esbuild": "^0.28.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "globals": "^17.7.0",
    "jiti": "^2.7.0",
    "prettier-plugin-css-order": "^2.2.0",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.10"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
